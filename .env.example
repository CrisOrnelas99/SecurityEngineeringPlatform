# Shared
NODE_ENV=production
LOG_FILE=/app/logs/app.log
SECURITY_CORE_BIN=/app/security_core/build/security_core
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
CORS_ORIGIN=http://localhost:5173

# Web App
PORT=3000
CSRF_COOKIE_SECRET=change-csrf-secret
UPLOAD_DIR=/app/uploads

# Python Threat Detection API
TDR_PORT=8000
WEB_LOG_PATH=/data/app.log
BLOCKLIST_PATH=/data/blocklist.json
LOCKED_USERS_PATH=/data/locked_users.json
ALERTS_PATH=/data/alerts.json
TIMELINE_PATH=/data/timeline.json

# Dashboard
VITE_TDR_API_URL=http://localhost:8000
